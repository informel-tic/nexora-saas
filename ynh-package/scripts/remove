#!/bin/bash
source /usr/share/yunohost/helpers
source _common.sh

UNINSTALL_MODE="${NEXORA_UNINSTALL_MODE:-preserve}"

ynh_script_progression --message="Stopping service..." --weight=1
systemctl stop "$app" || true

ynh_script_progression --message="Removing service integration..." --weight=1
if yunohost service status "$app" >/dev/null 2>&1; then
  yunohost service remove "$app"
fi

ynh_script_progression --message="Removing systemd service..." --weight=1
ynh_config_remove_systemd

ynh_script_progression --message="Removing NGINX configuration..." --weight=1
ynh_config_remove_nginx

ynh_script_progression --message="Removing log rotation..." --weight=1
ynh_config_remove_logrotate

if [ "$UNINSTALL_MODE" = "purge" ]; then
  ynh_script_progression --message="Purging Nexora data, logs and exports..." --weight=2
  ynh_safe_rm --file="$install_dir"
  ynh_safe_rm --file="$data_dir"
  ynh_safe_rm --file="/var/log/$app"
  ynh_safe_rm --file="/tmp/nexora-export"
  systemctl disable --now nexora-control-plane 2>/dev/null || true
  systemctl disable --now nexora-node-agent 2>/dev/null || true
  purge_requested="true"
else
  ynh_script_progression --message="Preserve mode: keeping Nexora data and exports." --weight=1
  purge_requested="false"
fi

# Audit report
python3 - <<PYEOF "$UNINSTALL_MODE" "$purge_requested" "$install_dir" "$data_dir"
import json, sys
from datetime import datetime, timezone
from pathlib import Path

mode, purged, inst_dir, d_dir = sys.argv[1:5]
report = {
    "timestamp": datetime.now(timezone.utc).isoformat(),
    "mode": mode,
    "purge_requested": purged == "true",
    "removed_paths": [],
    "preserved_paths": [],
    "notes": [],
}
if purged == "true":
    report["removed_paths"] = [inst_dir, d_dir, "/var/log/nexora", "/tmp/nexora-export"]
    report["notes"].append("Full purge completed.")
else:
    report["preserved_paths"] = [d_dir, "/tmp/nexora-export"]
    report["notes"].append("Preserve mode: data and exports kept.")
Path("/var/log/nexora-uninstall-report.json").write_text(
    json.dumps(report, indent=2, ensure_ascii=False), encoding="utf-8"
)
PYEOF

ynh_script_progression --message="Removal complete." --last
